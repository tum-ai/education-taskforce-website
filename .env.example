# Supabase Project Settings > Data API > Project URL.
# Must look like: https://abcdefghijklmnopqrst.supabase.co
# Do not use the Supabase dashboard URL.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Project Settings > API / Data API > publishable or anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Project Settings > API / Data API > secret key.
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# HMAC secret for Langdock/Lovable QR scan tokens. Required.
# Generate with: openssl rand -base64 48
# Rotating it invalidates all existing QR codes; reprint them from the admin QR pages.
LANGDOCK_QR_SIGNING_SECRET=

# Legacy Supabase projects may use this server-only key instead:
# SUPABASE_SERVICE_ROLE_KEY=
